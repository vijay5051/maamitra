# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Firebase (get from Firebase Console → Project Settings → Web App)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
# AUTH_DOMAIN: use your custom domain once it's added to Firebase →
# Authentication → Settings → Authorized domains. The OAuth popup URL
# users see in the address bar is whatever this resolves to.
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_custom_domain.example
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Anthropic — key is server-side only (Cloudflare Worker secret). Client uses the worker URL below.
EXPO_PUBLIC_CLAUDE_WORKER_URL=https://your-worker.workers.dev

# Firebase App Check (web). Register app in Firebase Console → App Check and paste the reCAPTCHA v3 site key.
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
# Dev only: set to "true" to enable the App Check debug token in the browser console,
# then paste it into Firebase Console → App Check → Apps → Debug tokens.
EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# Admin (set a strong password)
EXPO_PUBLIC_ADMIN_EMAIL=admin@maamitra.app
