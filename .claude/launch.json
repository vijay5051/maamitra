{
  "version": "0.0.1",
  "autoPort": true,
  "configurations": [
    {
      "name": "MaaMitra Web Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--clear"],
      "port": 8081
    },
    {
      "name": "MaaMitra Metro Bundler",
