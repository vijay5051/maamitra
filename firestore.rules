rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@maamitra.app' ||
        request.auth.token.email == 'vijay@maamitra.app'
      );
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Each user can read/write their own document. Admins can read all.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── Mood entries ──────────────────────────────────────────────────────────
    match /moods/{uid}/entries/{date} {
      allow read, write: if isOwner(uid);
    }

    // ── Saved answers ─────────────────────────────────────────────────────────
    match /saved_answers/{uid}/items/{itemId} {
      allow read, write: if isOwner(uid);
    }

    // ── AI Chat Threads (multi-thread history) ───────────────────────────────
    match /chats/{uid}/threads/{threadId} {
      allow read, write: if isOwner(uid);
    }

    // ── Community Posts (active collection used by the app) ──────────────────
    // Anyone signed in can read. Authors can create/delete their own.
    // Any signed-in user can update reactions/comments.
    match /communityPosts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.authorUid == request.auth.uid);

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.authorUid == request.auth.uid;
        allow delete: if isAdmin() ||
          // Comment author can delete their own comment
          (isSignedIn() && resource.data.authorUid == request.auth.uid) ||
          // Post owner can delete any comment on their post
          (isSignedIn() && get(/databases/$(database)/documents/communityPosts/$(postId)).data.authorUid == request.auth.uid);
      }
    }

    // ── Community posts (legacy collection used by admin panel) ──────────────
    match /community_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() ||
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'userReactions', 'comments']));
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.authorUid == request.auth.uid);
    }

    // ── Public Profiles ──────────────────────────────────────────────────────
    // Anyone signed in can read. Users can write their own.
    match /publicProfiles/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isSignedIn();
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── Follow Relationships ─────────────────────────────────────────────────
    // Anyone signed in can read follows. Users can create/delete their own.
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── Follow Requests ──────────────────────────────────────────────────────
    match /followRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── Blocks ───────────────────────────────────────────────────────────────
    match /blocks/{blockId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── Conversations (Direct Messages) ──────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();

      match /messages/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // Users can read/write their own notifications. Any signed-in user can
    // create notifications for others (e.g., reaction/comment/follow notifs).
    match /notifications/{uid}/items/{notifId} {
      allow read: if isOwner(uid);
      allow create: if isSignedIn();
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── App settings (admin only write, anyone signed-in can read) ────────────
    match /app_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Content collections: books, articles, products, schemes, yoga ─────────
    // Anyone signed in can read. Only admins can write.
    match /books/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /articles/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /products/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /schemes/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /yoga/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /vaccines/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Push notifications queue (admin write only) ───────────────────────────
    match /push_notifications/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Community (legacy collection used by admin content manager) ───────────
    match /community/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Support tickets ───────────────────────────────────────────────────────
    // Signed-in users can submit tickets; only admins read / manage them.
    match /supportTickets/{ticketId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

  }
}
