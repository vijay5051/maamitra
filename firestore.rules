rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    // Verified = signed in AND email_verified (true for Google sign-in automatically,
    // requires explicit verification for email/password sign-ups). Use this for any
    // write that touches other users: community posts, DMs, follows, blocks, etc.
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Admins: a user is admin if EITHER
    //   1. Their Firebase custom claim 'admin' is true, OR
    //   2. Their email is on the founder allow-list AND verified, OR
    //   3. Their users/{uid} doc has adminRole in {super, moderator, support, content}.
    //
    // (3) is the path used by the admin team UI — granting roles inside the
    // app rather than running scripts/set-admin.mjs. Reading the user doc is
    // fine here because every authenticated request already has its own doc
    // cached and rules can read documents.
    function adminRoleField(uid) {
      // get() throws if the doc is missing — guard with exists() first.
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data.adminRole
        : '';
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (request.auth.token.email_verified == true && (
          request.auth.token.email == 'admin@maamitra.app' ||
          request.auth.token.email == 'vijay@maamitra.app' ||
          request.auth.token.email == 'rocking.vsr@gmail.com' ||
          request.auth.token.email == 'divyashekhawat44@yahoo.in'
        )) ||
        adminRoleField(request.auth.uid) in ['super', 'moderator', 'support', 'content']
      );
    }
    // Super-only — destructive actions, role management, settings.
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (request.auth.token.email_verified == true && (
          request.auth.token.email == 'admin@maamitra.app' ||
          request.auth.token.email == 'vijay@maamitra.app' ||
          request.auth.token.email == 'rocking.vsr@gmail.com' ||
          request.auth.token.email == 'divyashekhawat44@yahoo.in'
        )) ||
        adminRoleField(request.auth.uid) == 'super'
      );
    }
    function isParticipant(participants) {
      return isSignedIn() && request.auth.uid in participants;
    }
    // Restrict which fields an update may touch.
    function onlyFields(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }
    // Basic size guards to stop abusive payloads.
    function shortText(s, max) {
      return s is string && s.size() <= max;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Admins can read & update arbitrary user docs, but only SUPER admins can
    // write the privileged 'adminRole' field — otherwise a moderator could
    // self-promote. We detect adminRole writes via affectedKeys.
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if (
        // Super admins can write anything, including adminRole.
        isSuperAdmin()
      ) || (
        // Owner / regular admin: allowed if NOT touching adminRole.
        (isOwner(uid) || isAdmin()) &&
        !('adminRole' in request.resource.data.diff(resource.data).affectedKeys())
      );
      allow delete: if isOwner(uid) || isSuperAdmin();
    }

    // ── Mood entries ──────────────────────────────────────────────────────────
    match /moods/{uid}/entries/{date} {
      allow read, write: if isOwner(uid);
    }

    // ── Saved answers ─────────────────────────────────────────────────────────
    match /saved_answers/{uid}/items/{itemId} {
      allow read, write: if isOwner(uid);
    }

    // ── AI Chat Threads (multi-thread history) ───────────────────────────────
    // Owner reads/writes their own threads. Admins can also read (but not
    // write) so the chat-usage analytics page (collectionGroup query on
    // `threads`) can compute per-user thread + message totals. The page
    // surfaces counts only — it does not display thread bodies in the UI,
    // but admins reading the docs can technically see content. That's the
    // same trust level as reading users/{uid} for support.
    match /chats/{uid}/threads/{threadId} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    // collectionGroup('threads') — used by /admin/chat-usage to roll up
    // per-user totals across every chats/* doc. Path-scoped rule above
    // doesn't satisfy collectionGroup; this wildcard does. Admin-only
    // because non-admins should never read another user's threads.
    match /{path=**}/threads/{threadId} {
      allow read: if isAdmin();
    }

    // collectionGroup('comments') — used by /admin/users/{uid} 360 to
    // count a user's authored comments across every post. Same shape:
    // the path-scoped rule on communityPosts/.../comments doesn't
    // satisfy collectionGroup queries; admins need this wildcard.
    match /{path=**}/comments/{commentId} {
      allow read: if isAdmin();
    }

    // ── Community Posts (active collection) ──────────────────────────────────
    // Public share links (/post/[id]) load a single post for anonymous
    // visitors to convert to signups. So `get` (direct doc lookup) is open
    // to everyone, but `list` (feed enumeration) still requires sign-in.
    // Authors own create/delete. Reactions & comments-count updates are
    // allowed for any signed-in user, but nothing else about the post
    // (text, authorUid, images…) may be touched.
    match /communityPosts/{postId} {
      allow get:    if true;
      allow list:   if isSignedIn();
      allow create: if isVerified() &&
        request.resource.data.authorUid == request.auth.uid &&
        shortText(request.resource.data.text, 5000);
      // Admins are intentionally NOT allowed to rewrite a user's words — that
      // was a privacy issue. They can only flip moderation flags (approved /
      // hidden + companion fields) or delete the post outright.
      // Reactions + comment counters: any signed-in user may bump these
      // since they're driven by social interactions, not post ownership.
      // Field names match what services/social.ts actually writes —
      // reactionsByUser, NOT userReactions; missing match was silently
      // denying every reaction toggle.
      allow update: if (isAdmin() && onlyFields(['approved', 'hidden', 'hiddenAt', 'hiddenReason', 'hiddenBy'])) ||
        (isSignedIn() && resource.data.authorUid == request.auth.uid &&
          shortText(request.resource.data.text, 5000)) ||
        (isSignedIn() && onlyFields(['reactions', 'reactionsByUser', 'commentCount', 'lastComment', 'lastCommentAt']));
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.authorUid == request.auth.uid);

      match /comments/{commentId} {
        allow read:   if isSignedIn();
        allow create: if isVerified() &&
          request.resource.data.authorUid == request.auth.uid &&
          shortText(request.resource.data.text, 2000);
        allow update: if isSignedIn() &&
          resource.data.authorUid == request.auth.uid &&
          onlyFields(['text', 'editedAt']) &&
          shortText(request.resource.data.text, 2000);
        allow delete: if isAdmin() ||
          (isSignedIn() && resource.data.authorUid == request.auth.uid) ||
          (isSignedIn() && get(/databases/$(database)/documents/communityPosts/$(postId)).data.authorUid == request.auth.uid);
      }
    }

    // ── Community posts (legacy collection) ──────────────────────────────────
    match /community_posts/{postId} {
      allow read:   if isSignedIn();
      allow create: if isVerified() &&
        request.resource.data.authorUid == request.auth.uid &&
        shortText(request.resource.data.text, 5000);
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.authorUid == request.auth.uid &&
          shortText(request.resource.data.text, 5000)) ||
        (isSignedIn() && onlyFields(['reactions', 'reactionsByUser', 'comments', 'commentCount', 'lastComment', 'lastCommentAt']));
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.authorUid == request.auth.uid);
    }

    // ── Public Profiles ──────────────────────────────────────────────────────
    // Anyone signed-in can read. Only the owner (or admin) can modify.
    // Followers/following counters are the one field a non-owner may bump
    // (e.g., when someone follows you, your followerCount increments).
    match /publicProfiles/{uid} {
      allow read:   if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin() ||
        (isSignedIn() && onlyFields(['followerCount', 'followingCount', 'postCount']));
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── Follow Relationships ─────────────────────────────────────────────────
    // Doc ID convention: `${fromUid}_${toUid}`. Either party in the edge
    // can create it: the follower (public self-follow) or the recipient
    // (when they accept a pending follow request). Either party can also
    // delete it (unfollow on sender side; remove-follower on recipient).
    match /follows/{followId} {
      allow read:   if isSignedIn();
      allow create: if isVerified() &&
        followId == request.resource.data.fromUid + '_' + request.resource.data.toUid &&
        (
          request.resource.data.fromUid == request.auth.uid ||
          request.resource.data.toUid == request.auth.uid
        );
      allow delete: if isSignedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
    }

    // ── Follow Requests ──────────────────────────────────────────────────────
    // Sender creates; only the recipient (or admin) can update/delete to
    // accept or reject. Sender may also delete (cancel their own request).
    match /followRequests/{requestId} {
      allow read:   if isSignedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow create: if isVerified() &&
        request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.toUid == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
    }

    // ── Blocks ───────────────────────────────────────────────────────────────
    // Only the blocker can create / delete their own block edge.
    match /blocks/{blockId} {
      allow read:   if isSignedIn() && (
        resource.data.blockerUid == request.auth.uid ||
        resource.data.blockedUid == request.auth.uid
      );
      allow create: if isVerified() &&
        request.resource.data.blockerUid == request.auth.uid;
      allow delete: if isSignedIn() &&
        resource.data.blockerUid == request.auth.uid;
    }

    // ── Conversations (Direct Messages) ──────────────────────────────────────
    // Only participants can read or modify a conversation and its messages.
    // `resource == null` guards protect reads on non-existent docs — without
    // them, a rule that reads resource.data.* blows up and Firestore returns
    // PERMISSION_DENIED for what should be a simple 'doc doesn't exist yet'.
    match /conversations/{convId} {
      allow read:   if isSignedIn() && (
        resource == null || isParticipant(resource.data.participants)
      );
      allow create: if isVerified() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      allow update: if isParticipant(resource.data.participants);
      // Participants may delete their own conversation (used during
      // account-delete to purge DMs). Admins may delete anything.
      allow delete: if isAdmin() || isParticipant(resource.data.participants);

      match /messages/{msgId} {
        // Guard the get() with exists() so a missing parent conversation
        // doesn't throw during rule evaluation. If the parent isn't there,
        // there's nothing to read anyway — return empty set cleanly.
        allow read: if isSignedIn() &&
          exists(/databases/$(database)/documents/conversations/$(convId)) &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        // services/messages.ts writes senderUid/senderName/senderPhoto —
        // match those field names.
        allow create: if isVerified() &&
          request.resource.data.senderUid == request.auth.uid &&
          exists(/databases/$(database)/documents/conversations/$(convId)) &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants &&
          shortText(request.resource.data.text, 4000);
        allow update: if isSignedIn() &&
          resource.data.senderUid == request.auth.uid &&
          onlyFields(['text', 'editedAt', 'read', 'readBy']) &&
          (!('text' in request.resource.data) || shortText(request.resource.data.text, 4000));
        // Senders delete their own messages. Admins delete anything.
        // Additionally, any participant of the parent conversation may
        // delete messages — this is required during account-delete where
        // the departing user wipes the whole thread (including messages
        // the other party sent to them).
        allow delete: if isAdmin() ||
          (isSignedIn() && resource.data.senderUid == request.auth.uid) ||
          (isSignedIn() &&
            exists(/databases/$(database)/documents/conversations/$(convId)) &&
            request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
      }
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // Owner reads/updates/deletes. Any signed-in user may create a notification
    // for another user, but only with a capped payload (no arbitrary fields).
    //
    // IMPORTANT: the whitelist below MUST match exactly what
    // services/social.ts createNotification() writes. An unknown field
    // makes hasOnly() false and the write is silently rejected, breaking
    // downstream features (follow requests, reaction/comment notifs).
    match /notifications/{uid}/items/{notifId} {
      allow read:   if isOwner(uid);
      allow create: if isVerified() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.auth.uid != uid &&  // can't notify yourself
        request.resource.data.keys().hasOnly(
          ['type', 'fromUid', 'fromName', 'fromPhotoUrl',
           'postId', 'postText', 'commentId',
           'text', 'emoji',
           'requestId',
           'createdAt', 'read']
        );
      allow update: if isOwner(uid) && onlyFields(['read']);
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── App settings (admin only write) ──────────────────────────────────────
    // Read open to all signed-in users so the banner + feature flags + theme
    // hydrate on app open. Write is admin-gated; manage_banner role gets in
    // through the same rule because content-editor needs banner access.
    match /app_settings/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Content collections: books, articles, products, schemes, yoga ────────
    match /books/{docId}    { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /articles/{docId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /products/{docId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /schemes/{docId}  { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /yoga/{docId}     { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /vaccines/{docId} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // ── Push jobs queue ──────────────────────────────────────────────────────
    // Each doc is a single push job consumed by the external dispatcher
    // (see functions/ README). Shape:
    //   { kind: 'personal' | 'broadcast',
    //     toUid?: string,            // personal only — dispatcher looks up tokens
    //     audience?: 'all' | 'pregnant' | 'newborn' | 'toddler',
    //     title, body, data?: {...}, createdAt, status: 'pending' | 'sent' | 'failed',
    //     fromUid?: string            // author of the event, for abuse tracing }
    //
    // Create rules:
    //   - broadcast jobs: admin only (this is the megaphone).
    //   - personal jobs: any verified user can enqueue, but only if they
    //     name themselves as fromUid AND the target is NOT themselves.
    //     Size caps keep payloads sane.
    // Read: admin + dispatcher service account (admin covers both in our
    //     setup). Update: admin (dispatcher marks status). Delete: admin.
    match /push_queue/{jobId} {
      allow read:   if isAdmin();
      allow create: if (isAdmin()) ||
        (isVerified() &&
          request.resource.data.kind == 'personal' &&
          request.resource.data.fromUid == request.auth.uid &&
          request.resource.data.toUid is string &&
          request.resource.data.toUid != request.auth.uid &&
          shortText(request.resource.data.title, 120) &&
          shortText(request.resource.data.body, 300) &&
          // notifType is optional but when present must be one of the
          // recognised in-app types — lets the dispatcher gate on
          // per-topic prefs without us trusting arbitrary strings.
          (!('notifType' in request.resource.data) ||
            request.resource.data.notifType in
              ['reaction', 'comment', 'follow_request', 'follow_accepted', 'message']));
      allow update, delete: if isAdmin();

      // Per-recipient delivery rows written by the dispatcher Cloud
      // Function. Admin-only read so the Outbox UI can render "who
      // got it / who failed". Writes happen via the admin SDK and
      // bypass these rules entirely.
      match /delivery_report/{rowId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // ── Push notifications log (admin-authored broadcasts, legacy) ──────────
    match /push_notifications/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Community (legacy content admin) ─────────────────────────────────────
    match /community/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Support tickets ──────────────────────────────────────────────────────
    // Submitters may read their own ticket; admins read/manage all.
    match /supportTickets/{ticketId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        shortText(request.resource.data.subject, 200) &&
        shortText(request.resource.data.message, 5000);
      allow update, delete: if isAdmin();
    }

    // ── Admin audit log ──────────────────────────────────────────────────────
    // Append-only. Any signed-in admin can write (the client-side service does
    // this from every action site). Read is admin-only. Updates and deletes
    // are forbidden so the log is tamper-resistant.
    match /admin_audit/{entryId} {
      allow read:   if isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.action is string &&
        request.resource.data.action.size() <= 64;
      allow update, delete: if false;
    }

    // ── Scheduled pushes ─────────────────────────────────────────────────────
    // Admins schedule a future broadcast OR a custom-list push here. A Cloud
    // Scheduler-driven function (`processScheduledPushes`) promotes due
    // entries into push_queue (broadcast = 1 doc, custom = N docs). Mortal
    // users have no business reading or writing this.
    match /scheduled_pushes/{schedId} {
      allow read:   if isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.kind in ['broadcast', 'custom'] &&
        shortText(request.resource.data.title, 120) &&
        shortText(request.resource.data.body, 300) && (
          (request.resource.data.kind == 'broadcast' &&
            request.resource.data.audience in ['all', 'pregnant', 'newborn', 'toddler'])
          ||
          (request.resource.data.kind == 'custom' &&
            request.resource.data.targetUids is list &&
            request.resource.data.targetUids.size() > 0 &&
            request.resource.data.targetUids.size() <= 1000)
        );
      allow update, delete: if isAdmin();
    }

    // ── Tester feedback ──────────────────────────────────────────────────────
    // One-time survey submissions while MaaMitra is in private beta. Any
    // signed-in user may submit (we also accept an unauthed uid=null path —
    // auth is still required for the write itself, but we don't pin the
    // doc's uid to auth.uid so that a shared-device tester can submit
    // without first signing in elsewhere). Only admins can read — the
    // aggregate dashboard lives at /admin/feedback and must stay private
    // so raw price signal doesn't leak to anyone who discovers the
    // collection path.
    match /testerFeedback/{feedbackId} {
      allow read:   if isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        shortText(request.resource.data.priceBand, 40) &&
        shortText(request.resource.data.wouldPayAnnual, 10) &&
        (!('note' in request.resource.data) || shortText(request.resource.data.note, 500)) &&
        (!('userName' in request.resource.data) || shortText(request.resource.data.userName, 120)) &&
        (!('userEmail' in request.resource.data) || shortText(request.resource.data.userEmail, 200));
      allow update, delete: if isAdmin();
    }

    // ── Closed-beta feedback (micro-surveys + free-form reports) ──────────────
    // Any signed-in user can submit; only admins can read. The doc must
    // pin its uid to auth.uid so a malicious tester can't impersonate
    // another user's feedback.
    match /feedback/{feedbackId} {
      allow read:   if isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        shortText(request.resource.data.type, 40) &&
        (!('answer' in request.resource.data) || shortText(request.resource.data.answer, 200)) &&
        (!('question' in request.resource.data) || shortText(request.resource.data.question, 300)) &&
        (!('freeText' in request.resource.data) || shortText(request.resource.data.freeText, 1000)) &&
        (!('surveyKey' in request.resource.data) || shortText(request.resource.data.surveyKey, 20)) &&
        (!('platform' in request.resource.data) || shortText(request.resource.data.platform, 20)) &&
        (!('appVersion' in request.resource.data) || shortText(request.resource.data.appVersion, 40));
      allow update, delete: if isAdmin();
    }
  }
}
