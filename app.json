{
  "expo": {
    "name": "MaaMitra",
    "slug": "maamitra",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdf6ff"
    },
    "scheme": "maamitra",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.maamitra.app",
      "buildNumber": "5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "MaaMitra uses your microphone so you can speak to the chat in your preferred language.",
        "NSSpeechRecognitionUsageDescription": "MaaMitra converts your voice to text so you can ask questions hands-free."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fdf6ff"
      },
      "package": "in.maamitra.app",
      "versionCode": 17,
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "MaaMitra",
      "shortName": "MaaMitra",
      "description": "Your AI-powered Indian motherhood companion",
      "themeColor": "#1C1033",
      "backgroundColor": "#1C1033",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fdf6ff",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#7C4DFF"
        }
      ],
      "@react-native-google-signin/google-signin",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "extraMavenRepos": []
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "MaaMitra uses your microphone so you can speak to the chat in your preferred language.",
          "speechRecognitionPermission": "MaaMitra converts your voice to text so you can ask questions hands-free.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "7780cd0c-fe85-4687-b885-dee85f957df6"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/7780cd0c-fe85-4687-b885-dee85f957df6"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
