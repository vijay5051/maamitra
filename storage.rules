rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars — stored as avatars/{uid}.<ext>
    // Any signed-in user can read (public avatars). Only the owner can write.
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches(request.auth.uid + '\\..*')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|heic|heif|gif)');
    }

    // Community post images — users can upload only into their own folder
    match /posts/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|heic|heif|gif)');
    }

    // Child profile photos — kid-avatars/{uid}/{kidId}.<ext>
    // Same model as posts: only the parent uploads + reads under their own
    // uid path. Any signed-in user can read so we can render avatars in
    // shared contexts (community, DMs) without per-file ACLs.
    match /kid-avatars/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|heic|heif|gif)');
    }

    // DM image attachments — path is dm-images/{convId}/{uid}_{timestamp}.jpg
    // Any signed-in user can read (conversation participants need access on
    // both sides; we gate who can see the conversation itself via Firestore).
    // Only the uploader can write, and only into a file whose name starts
    // with their UID so one party can't impersonate the other.
    match /dm-images/{convId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches(request.auth.uid + '_.*')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|heic|heif|gif)');
    }

    // UGC submission photos (M6) — ugc/{submissionId}/photo.jpg
    // Any signed-in user can upload during submission (the Firestore rule
    // gates the actual ugc_submissions doc to that same user). Reads
    // are admin-only since the queue is internal until rendered.
    match /ugc/{submissionId}/{fileName} {
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && (request.auth.token.admin == true
            || request.auth.token.email == 'rocking.vsr@gmail.com');
      allow write: if request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|heic|heif)');
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
